{
  "name": "uwf_backend_v2",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "ts-node src/index.ts",
    "sequelize": "sequelize-cli",
    "db:migrate": "sequelize-cli db:migrate --config src/database/config/config.js --migrations-path migrations --models-path src/models --seeders-path seeders",
    "db:seed": "sequelize-cli db:seed:all --config src/database/config/config.js --migrations-path migrations --models-path src/models --seeders-path seeders"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pg": "^8.16.2",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "uuid": "^14.0.0"
  },
  "overrides": {
    "uuid": "file:vendor/uuid"
  },
  "sequelize": {
    "config": "src/database/config/config.js",
    "models-path": "src/models",
    "migrations-path": "migrations",
    "seeders-path": "seeders"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^24.0.3",
    "@types/sequelize": "^4.28.20",
    "nodemon": "^3.1.10",
    "sequelize-cli": "^6.6.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "overrides": {
      "minimatch": "^9.0.7",
      "brace-expansion": "^2.0.3",
      "picomatch": "^2.3.2",
      "lodash": "^4.17.21",
      "underscore": "^1.13.8",
      "dottie": "^2.0.7",
      "qs": "^6.14.2",
      "path-to-regexp": "^8.4.0",
      "diff": "^4.0.4"
    }
  }
}
